# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ==========================================
# CONFIGURAÇÕES DO CAPROVER (VPS HETZNER)
# ==========================================

# Database Postgres
DATABASE_URL="postgresql://user:password@srv-captain--postgres-db:5432/inspecaov2?schema=public"

# Storage MinIO S3
MINIO_ENDPOINT="http://srv-captain--minio:9000"
MINIO_ACCESS_KEY="seu_access_key"
MINIO_SECRET_KEY="sua_secret_key"
MINIO_BUCKET="inspecaov2"

# Servidor de Email (SMTP)
SMTP_HOST="smtp.seudominio.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="contato@seudominio.com"
SMTP_PASS="sua_senha_segura"

# Segurança API
JWT_SECRET="chave_super_secreta_para_tokens"
PORT="80"
